var server = app.listen(7077, function () {
  console.log("server started");
});
var io = socketIO.listen(server, { log: true, origins: "*:*" });
io.origins("*:*");
io.on("connection", function (socket) {
  console.log("New user connected", socket.id);
  socket.on("connectUser", function (user_id) {
    console.log("hi " + user_id);
    // setTimeout(function () {
    utils.start_session(user_id, socket.id);
    //  },150)
  });

  socket.on("disconnect", () => {
    console.log("user disconnected", socket.id);
    utils.end_session(socket.id);
  });
});
